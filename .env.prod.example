# Production env for the AWS EC2 deployment. Copy to `.env` on the box
# (NOT committed) and fill in. docker compose reads `.env` automatically.
#
#   cp .env.prod.example .env  &&  edit .env
#
# Keep this file secret-free in git — it's a template. Real values live only in
# the `.env` on the server.

# Postgres password for the self-hosted DB (compose injects it into both the
# postgres container and the backend's DATABASE_URL). Use a URL-safe value —
# base64 can emit / + = which break the postgres:// URL. Use hex:
#   openssl rand -hex 24
POSTGRES_PASSWORD=change-me-long-random

# CORS allowlist so the browser UI on the custom domain can call the API.
CORS_ORIGINS=https://market.clawmint.space

# Untrusted-code sandbox. EC2 HAS a Docker daemon, so docker-mode works here
# (unlike Fly). Leave unset for the in-process runner (trusted/seed tasks only —
# NOT a security boundary; in production the guard makes the FIRST submission
# verification throw without docker-mode, unless you also set
# SANDBOX_ALLOW_LOCAL=1 deliberately. The backend still boots — verification
# just hard-fails — so set this up before opening to untrusted submissions).
#
# To accept untrusted submissions, set SANDBOX_MODE=docker. This requires (see
# docs/deploy.md "Untrusted-code sandbox", and DO IT IN THIS ORDER before the
# deploy that enables it, so the first real verification works):
#   1. instance with >=2 GB RAM (t3.micro 1 GB OOMs on sibling containers)
#   2. sudo mkdir -p /srv/verify   (shared work dir, bind-mounted by compose)
#   3. the clawmint-sandbox:latest image (deploy.yml builds it; or build by hand:
#      docker build -t clawmint-sandbox:latest deploy/sandbox)
#   4. DOCKER_GID below = the host's docker group, so the unprivileged backend
#      user can reach the mounted socket:  getent group docker | cut -d: -f3
# SANDBOX_MODE=docker
# SANDBOX_IMAGE=clawmint-sandbox:latest
# VERIFY_TMP=/srv/verify
# DOCKER_GID=988

# Optional — see backend/.env.example for the full list (ADMIN_TOKEN,
# LLM_API_KEY, RISK_ENGINE_URL/KEY, DATABASE_SSL, rate-limit tuning).
