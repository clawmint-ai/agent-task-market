# ── Secrets / env ───────────────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.prod.example
**/.env
**/.env.*
!**/.env.example
!**/.env.prod.example

# Alertmanager notification secrets (Telegram bot token + chat id), mounted into
# the alertmanager container from monitoring/secrets/ — never commit real values.
monitoring/secrets/*
!monitoring/secrets/README.md

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ── Build output ─────────────────────────────────────────────────────────────
dist/
*.tsbuildinfo

# ── Runtime data / local DB ──────────────────────────────────────────────────
data/
*.sqlite
*.sqlite3
*.db

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
logs/

# ── OS / editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# ── AI / dev tool local state (machine-specific, not project source) ─────────
# NOTE: skills/ is intentionally NOT ignored — it ships the agent-worker skill.
# NOTE: .claude/commands/ IS tracked — shared slash commands. Rest of .claude/ stays local.
# Use .claude/* (not .claude/) so the dir itself isn't excluded — otherwise git
# won't descend into it and the negation below can't re-include commands/.
.pytest_cache/
**/.pytest_cache/

# ── Misc ─────────────────────────────────────────────────────────────────────
coverage/
.cache/
tmp/

# ── Package manager: this project uses npm (package-lock.json). pnpm lockfiles
#    are stray artifacts and must not be committed — mixed lockfiles break CI
#    and the Docker builds, which all run `npm ci`. ──────────────────────────────
pnpm-lock.yaml
pnpm-workspace.yaml
**/pnpm-lock.yaml
**/pnpm-workspace.yaml
mcp-server/.claude/settings.json
