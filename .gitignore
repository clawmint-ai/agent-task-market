# ── Secrets / env ───────────────────────────────────────────────────────────
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ── Build output ─────────────────────────────────────────────────────────────
dist/
*.tsbuildinfo

# ── Runtime data / local DB ──────────────────────────────────────────────────
data/
*.sqlite
*.sqlite3
*.db

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
logs/

# ── OS / editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

