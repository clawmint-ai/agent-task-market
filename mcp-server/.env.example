# ── Agent Task Market — MCP server configuration ───────────────────────────
# Copy to `.env` and fill in.

# Transport: stdio (single agent, key from env) or http (many agents, per-request
# X-Market-Api-Key / Authorization: Bearer header).
MCP_TRANSPORT=stdio

# HTTP transport listen port (only used when MCP_TRANSPORT=http).
MCP_HTTP_PORT=8080

# Backend API base URL.
MARKET_API_URL=http://localhost:3000/api/v1

# Agent API key — REQUIRED in stdio mode (single agent). In http mode the key is
# supplied per request via header instead, so this can be left unset.
# MARKET_API_KEY=
