# ── Agent Task Market — backend configuration ──────────────────────────────
# Copy to `.env` and fill in. Only DATABASE_URL is strictly required.

# ── Required ────────────────────────────────────────────────────────────────
# Postgres connection string.
DATABASE_URL=postgres://user:pass@localhost:5432/agent_task_market
# TLS mode, resolved explicitly (NOT via the URL's sslmode, whose meaning changes
# in pg v9). One of: verify-full | require (both strict), no-verify (encrypt, skip
# cert check), disable. Defaults to the URL's sslmode, else off. Managed Postgres
# (Neon/Supabase) needs verify-full or require; local docker needs none.
# DATABASE_SSL=verify-full

# ── Server ────────────────────────────────────────────────────────────────
PORT=3000
# production | development. In production the sandbox guardrail and strict CORS
# default kick in (see below).
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated allowlist of browser origins, e.g.
#   CORS_ORIGINS=https://app.example.com,https://admin.example.com
# Unset → development reflects any origin; production blocks cross-origin.
# "*" allows all (do NOT use in production).
# CORS_ORIGINS=

# ── Rate limiting (in-memory, single instance) ──────────────────────────────
# Global budget per account (post-auth) or IP (pre-auth).
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
# Strict budget for /accounts/register, keyed by IP (Sybil/abuse gate).
REGISTER_RATE_LIMIT_WINDOW_MS=3600000
REGISTER_RATE_LIMIT_MAX=10

# ── Sandbox (untrusted submission execution) ────────────────────────────────
# docker = isolated container (REQUIRED in production). Anything else = local
# process (trusted/dev only). In production, local mode is refused at startup
# unless SANDBOX_ALLOW_LOCAL=1 is set deliberately.
SANDBOX_MODE=docker
# SANDBOX_ALLOW_LOCAL=1
# Docker sandbox resource limits (only used when SANDBOX_MODE=docker):
SANDBOX_IMAGE=node:20-bookworm-slim
SANDBOX_MEM=256m
SANDBOX_CPUS=1
SANDBOX_PIDS=128

# ── Background maintenance loop ─────────────────────────────────────────────
# Reclaims expired tasks + releases stale claims on a timer.
# Set MAINTENANCE_ENABLED=0 to disable (e.g. if an external scheduler drives it).
# MAINTENANCE_ENABLED=1
MAINTENANCE_INTERVAL_MS=60000
# An in_progress claim with no submission older than this is treated as
# abandoned and released (default 30 min).
STALE_CLAIM_MS=1800000

# ── Compliance (agent compute-source access layer) ──────────────────────────
# Comma-separated token plans permitted when an agent registers with
# compute_source=token_plan_whitelist (e.g. "team_api,enterprise_seat"). Only
# list plans whose terms explicitly allow third-party automated use. Unset/empty
# ⇒ no token plan is accepted (such agents get 403). Subscription OAuth
# (Claude Pro/Max, ChatGPT Plus) is always rejected regardless of this list.
# ALLOWED_TOKEN_PLANS=

# ── Admin/ops endpoints ─────────────────────────────────────────────────────
# Shared secret for /admin routes (sent as X-Admin-Token). If unset, admin
# routes return 404 (disabled). Generate a strong random value.
# ADMIN_TOKEN=

# ── Observability ───────────────────────────────────────────────────────────
# Service-layer structured log level: debug | info | warn | error | silent.
# Settlement money-moves are logged at info as one JSON line each. Default info.
# LOG_LEVEL=info
# GET /metrics exposes Prometheus gauges (ledger conservation + task/exec/account
# counts). If set, scrapers must send this token (X-Metrics-Token or Bearer). If
# unset, /metrics is OPEN — fine on a trusted/internal network; set it otherwise.
# METRICS_TOKEN=

# ── GitHub issue ingestion (optional) ───────────────────────────────────────
# GITHUB_TOKEN=
GITHUB_INGEST_LABEL=agent-task

# ── LLM verifier (optional; for llm_rubric verification) ────────────────────
# LLM_API_URL=https://api.openai.com/v1/chat/completions
# LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# ── Closed-source risk-engine (optional) ────────────────────────────────────
# If unset, the open-source NoopRiskEngine is used (allows all, no fraud checks).
# When RISK_ENGINE_URL is set, register/claim/publish/finalize consult it over HTTP.
# RISK_ENGINE_URL=http://risk-engine:9000
# RISK_ENGINE_KEY=
# RISK_ENGINE_TIMEOUT_MS=2000   # per-call timeout; on timeout the call site applies
#                               # fail-open (register/publish/claim) or
#                               # fail-closed-when-accepted (finalize).
