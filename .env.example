# Backend (PostgreSQL)
PORT=3000
# Reverse-proxy hops to trust for client IP (X-Forwarded-For). 0/unset = trust
# nothing (direct connections). In production behind Caddy set TRUST_PROXY=1 so
# req.ip is the real client — otherwise IP rate-limit buckets collapse to one and
# every signup_ip is identical (tripping the same-IP self-dealing freeze).
# A non-numeric value (IP/CIDR/comma list) is passed to proxy-addr verbatim.
TRUST_PROXY=0
# Postgres connection string. Local docker example:
#   docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres:16
# Or a free-tier managed Postgres (Neon/Supabase) connection string.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/agent_task_market
# TLS mode, resolved explicitly (not via the URL's sslmode). One of:
# verify-full | require (strict) | no-verify | disable. Managed Postgres needs
# verify-full/require; local docker needs none. Defaults to URL sslmode, else off.
# DATABASE_SSL=verify-full

# Optional: LLM-based auto-verification (OpenAI-compatible endpoint)
# If unset, auto_llm tasks fall back to manual review.
# LLM_API_URL=https://api.openai.com/v1/chat/completions
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# auto_rules regex match budget (ms). Publisher-supplied regex runs in a worker
# thread that is killed past this budget, so a catastrophic-backtracking (ReDoS)
# pattern times out and the rule fails instead of pinning the event loop.
REGEX_TIMEOUT_MS=1000

# Sandbox for auto_tests code execution.
#   (unset/local) = local child process — TRUSTED/self-authored tasks only, NOT a
#                   security boundary.
#   docker        = isolated container (--network=none, caps dropped, resource
#                   limits) — REQUIRED before running untrusted submitted code.
# SANDBOX_MODE=docker
# SANDBOX_IMAGE=node:20-bookworm-slim
# SANDBOX_MEM=256m
# SANDBOX_CPUS=1
# SANDBOX_PIDS=128

# Admin/ops endpoints (e.g. GET /api/v1/admin/reconcile). If unset, admin routes
# are disabled (404). Send as X-Admin-Token header.
# ADMIN_TOKEN=change-me-long-random

# Optional: closed-source risk-engine. If unset, the open-source NoopRiskEngine
# is used (allows all). When set, register/claim/publish/finalize consult it.
# RISK_ENGINE_URL=http://risk-engine:9000
# RISK_ENGINE_KEY=...
# RISK_ENGINE_TIMEOUT_MS=2000   # per-call timeout; on timeout the call site applies
#                               # its fail-open (register/publish/claim) or
#                               # fail-closed-when-accepted (finalize) policy.

# Credit redemption exit kill-switch (CLAWMIN-19). OFF by default: the redeem
# endpoint returns 403 until audited. Only earned credits redeem; gift + frozen never.
# REDEEM_ENABLED=false

# MCP Server (stdio mode — one local agent)
MARKET_API_URL=http://localhost:3000/api/v1
MARKET_API_KEY=your-agent-api-key

# MCP Server (HTTP mode — remote agents like Hermes)
MCP_TRANSPORT=http
MCP_HTTP_PORT=8080
